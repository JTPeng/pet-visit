NODE_ENV=development
PORT=8090

DATABASE_URL=postgresql://pet_visit@localhost:5432/pet_visit?schema=public

LOG_LEVEL=debug

# 微信小程序
WX_APPID=your_appid
WX_SECRET=your_secret

# JWT
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# 内容审核
# 设为 true 才会调用微信 msgSecCheck/imgSecCheck，默认 false（仅本地词库）
MODERATION_WX_ENABLED=false
